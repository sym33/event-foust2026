PREFIX erp: <https://w3id.org/event-retyping-pattern/>

SELECT DISTINCT ?occurrence ?currentSortal
WHERE {
  ?act erp:produces ?ice .
  ?ice erp:assertsTyping ?typing .
  ?typing erp:typingOccurrence ?occurrence ;
          erp:typingSortal ?currentSortal .
  FILTER NOT EXISTS {
    ?laterAct erp:produces ?laterICE .
    ?laterICE erp:reorients ?ice ;
              erp:hasReorientationBasis ?basis ;
              erp:assertsTyping ?laterTyping .
    ?basis erp:basisForReorientationOf ?ice ;
           erp:maintenancePurpose ?purpose ;
           erp:basisScope ?basisScope ;
           erp:hasAuthorizingSource ?authorizingSource .
    ?act erp:precedes ?laterAct .
    ?laterTyping erp:typingOccurrence ?occurrence ;
                 erp:typingSortal ?laterSortal .
    FILTER (?currentSortal != ?laterSortal)
  }
}
ORDER BY ?occurrence ?currentSortal
