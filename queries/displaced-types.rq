PREFIX erp: <https://w3id.org/event-retyping-pattern/>

SELECT DISTINCT ?occurrence ?displacedSortal
WHERE {
  ?earlierAct erp:produces ?earlierICE ;
              erp:precedes ?laterAct .
  ?laterAct erp:produces ?laterICE .
  ?earlierICE erp:assertsTyping ?earlierTyping .
  ?laterICE erp:assertsTyping ?laterTyping ;
            erp:reorients ?earlierICE ;
            erp:hasReorientationBasis ?basis .
  ?basis erp:basisForReorientationOf ?earlierICE ;
         erp:maintenancePurpose ?purpose ;
         erp:basisScope ?basisScope ;
         erp:hasAuthorizingSource ?authorizingSource .
  ?earlierTyping erp:typingOccurrence ?occurrence ;
                 erp:typingSortal ?displacedSortal .
  ?laterTyping erp:typingOccurrence ?occurrence ;
               erp:typingSortal ?laterSortal .
  FILTER (?displacedSortal != ?laterSortal)
}
ORDER BY ?occurrence ?displacedSortal
