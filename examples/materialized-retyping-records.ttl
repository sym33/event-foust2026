@prefix erp: <https://w3id.org/event-retyping-pattern/> .
@prefix ex: <https://w3id.org/event-retyping-pattern/example/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

ex:disease_record rdf:type erp:RetypingRecord .
ex:disease_record erp:retypingOccurrence ex:disease_episode_17 .
ex:disease_record erp:earlierClassificationAct ex:classify_disease_1 .
ex:disease_record erp:laterClassificationAct ex:classify_disease_2 .
ex:disease_record erp:earlierSortal ex:AtypicalPneumoniaEpisode .
ex:disease_record erp:laterSortal ex:COVID19Episode .
ex:disease_record erp:fromTyping ex:typing_disease_1 .
ex:disease_record erp:toTyping ex:typing_disease_2 .
ex:disease_record erp:hasReorientationBasis ex:basis_disease_2 .

ex:seismic_record rdf:type erp:RetypingRecord .
ex:seismic_record erp:retypingOccurrence ex:seismic_event_42 .
ex:seismic_record erp:earlierClassificationAct ex:classify_seismic_1 .
ex:seismic_record erp:laterClassificationAct ex:classify_seismic_2 .
ex:seismic_record erp:earlierSortal ex:TectonicEarthquake .
ex:seismic_record erp:laterSortal ex:InducedSeismicity .
ex:seismic_record erp:fromTyping ex:typing_seismic_1 .
ex:seismic_record erp:toTyping ex:typing_seismic_2 .
ex:seismic_record erp:hasReorientationBasis ex:basis_seismic_2 .

ex:chain_record_12 rdf:type erp:RetypingRecord .
ex:chain_record_12 erp:retypingOccurrence ex:chain_event .
ex:chain_record_12 erp:earlierClassificationAct ex:classify_chain_1 .
ex:chain_record_12 erp:laterClassificationAct ex:classify_chain_2 .
ex:chain_record_12 erp:earlierSortal ex:T1 .
ex:chain_record_12 erp:laterSortal ex:T2 .
ex:chain_record_12 erp:fromTyping ex:typing_chain_1 .
ex:chain_record_12 erp:toTyping ex:typing_chain_2 .
ex:chain_record_12 erp:hasReorientationBasis ex:basis_chain_2 .

ex:chain_record_23 rdf:type erp:RetypingRecord .
ex:chain_record_23 erp:retypingOccurrence ex:chain_event .
ex:chain_record_23 erp:earlierClassificationAct ex:classify_chain_2 .
ex:chain_record_23 erp:laterClassificationAct ex:classify_chain_3 .
ex:chain_record_23 erp:earlierSortal ex:T2 .
ex:chain_record_23 erp:laterSortal ex:T3 .
ex:chain_record_23 erp:fromTyping ex:typing_chain_2 .
ex:chain_record_23 erp:toTyping ex:typing_chain_3 .
ex:chain_record_23 erp:hasReorientationBasis ex:basis_chain_3 .
