@prefix erp: <https://w3id.org/event-retyping-pattern/> .
@prefix ex: <https://w3id.org/event-retyping-pattern/example/> .

ex:StableSyndrome a erp:EventSortal .
ex:AlternativeLabel a erp:EventSortal .
ex:contested_event a erp:Occurrent .
ex:classify_contested_1 a erp:ClassificationAct .
ex:classify_contested_2 a erp:ClassificationAct .
ex:ice_contested_1 a erp:InformationContentEntity .
ex:ice_contested_2 a erp:InformationContentEntity .
ex:typing_contested_1 a erp:TypingAssertion .
ex:typing_contested_2 a erp:TypingAssertion .
ex:classify_contested_1 erp:produces ex:ice_contested_1 .
ex:classify_contested_2 erp:produces ex:ice_contested_2 .
ex:classify_contested_1 erp:precedes ex:classify_contested_2 .
ex:ice_contested_1 erp:about ex:contested_event .
ex:ice_contested_2 erp:about ex:contested_event .
ex:ice_contested_1 erp:assertsTyping ex:typing_contested_1 .
ex:ice_contested_2 erp:assertsTyping ex:typing_contested_2 .
ex:typing_contested_1 erp:typingOccurrence ex:contested_event .
ex:typing_contested_2 erp:typingOccurrence ex:contested_event .
ex:typing_contested_1 erp:typingSortal ex:StableSyndrome .
ex:typing_contested_2 erp:typingSortal ex:AlternativeLabel .
