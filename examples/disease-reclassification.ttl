@prefix erp: <https://w3id.org/event-retyping-pattern/> .
@prefix ex: <https://w3id.org/event-retyping-pattern/example/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:AtypicalPneumoniaEpisode a erp:EventSortal .
ex:COVID19Episode a erp:EventSortal .
ex:CuratorTeam a erp:Agent .
ex:PublicHealthCaseDefinitionWorkflow a erp:AuthorizationSource .
ex:disease_episode_17 a erp:Occurrent .
ex:classify_disease_1 a erp:ClassificationAct .
ex:classify_disease_2 a erp:ClassificationAct .
ex:ice_disease_1 a erp:InformationContentEntity .
ex:ice_disease_2 a erp:InformationContentEntity .
ex:basis_disease_2 a erp:ReorientationBasis .
ex:typing_disease_1 a erp:TypingAssertion .
ex:typing_disease_2 a erp:TypingAssertion .
ex:classify_disease_1 erp:hasAgent ex:CuratorTeam .
ex:classify_disease_2 erp:hasAgent ex:CuratorTeam .
ex:classify_disease_1 erp:produces ex:ice_disease_1 .
ex:classify_disease_2 erp:produces ex:ice_disease_2 .
ex:classify_disease_1 erp:precedes ex:classify_disease_2 .
ex:ice_disease_1 erp:about ex:disease_episode_17 .
ex:ice_disease_2 erp:about ex:disease_episode_17 .
ex:ice_disease_1 erp:assertsTyping ex:typing_disease_1 .
ex:ice_disease_2 erp:assertsTyping ex:typing_disease_2 .
ex:typing_disease_1 erp:typingOccurrence ex:disease_episode_17 .
ex:typing_disease_2 erp:typingOccurrence ex:disease_episode_17 .
ex:typing_disease_1 erp:typingSortal ex:AtypicalPneumoniaEpisode .
ex:typing_disease_2 erp:typingSortal ex:COVID19Episode .
ex:ice_disease_2 erp:reorients ex:ice_disease_1 .
ex:ice_disease_1 erp:refiguredBy ex:ice_disease_2 .
ex:ice_disease_1 erp:hasHistoricalRole erp:DisplacedFrame .
ex:ice_disease_1 erp:hasHistoricalRole erp:ReviewRelevantCommitment .
ex:ice_disease_2 erp:hasHistoricalRole erp:CurrentFrame .
ex:ice_disease_2 erp:hasReorientationBasis ex:basis_disease_2 .
ex:basis_disease_2 erp:basisForReorientationOf ex:ice_disease_1 .
ex:basis_disease_2 erp:maintenancePurpose "case maintenance after stabilized diagnostic criteria" .
ex:basis_disease_2 erp:basisScope "public-health surveillance case maintenance" .
ex:basis_disease_2 erp:hasAuthorizingSource ex:PublicHealthCaseDefinitionWorkflow .

ex:CaseReviewPolicy a erp:ReviewPolicy .
ex:disease_line_list_entry a erp:InformationContentEntity .
ex:disease_exposure_map a erp:InformationContentEntity .
ex:disease_line_list_entry erp:dependsOnTyping ex:ice_disease_1 .
ex:disease_exposure_map erp:dependsOnTyping ex:ice_disease_1 .
ex:basis_disease_2 erp:hasReviewPolicy ex:CaseReviewPolicy .
