@prefix erp: <https://w3id.org/event-retyping-pattern/> .
@prefix ex: <https://w3id.org/event-retyping-pattern/example/> .

ex:StableSyndrome a erp:EventSortal .
ex:enrichment_event a erp:Occurrent .
ex:classify_enrichment_1 a erp:ClassificationAct .
ex:classify_enrichment_2 a erp:ClassificationAct .
ex:ice_enrichment_1 a erp:InformationContentEntity .
ex:ice_enrichment_2 a erp:InformationContentEntity .
ex:typing_enrichment_1 a erp:TypingAssertion .
ex:typing_enrichment_2 a erp:TypingAssertion .
ex:classify_enrichment_1 erp:produces ex:ice_enrichment_1 .
ex:classify_enrichment_2 erp:produces ex:ice_enrichment_2 .
ex:classify_enrichment_1 erp:precedes ex:classify_enrichment_2 .
ex:ice_enrichment_1 erp:about ex:enrichment_event .
ex:ice_enrichment_2 erp:about ex:enrichment_event .
ex:ice_enrichment_1 erp:assertsTyping ex:typing_enrichment_1 .
ex:ice_enrichment_2 erp:assertsTyping ex:typing_enrichment_2 .
ex:typing_enrichment_1 erp:typingOccurrence ex:enrichment_event .
ex:typing_enrichment_2 erp:typingOccurrence ex:enrichment_event .
ex:typing_enrichment_1 erp:typingSortal ex:StableSyndrome .
ex:typing_enrichment_2 erp:typingSortal ex:StableSyndrome .
