@prefix erp: <https://w3id.org/event-retyping-pattern/> .
@prefix ex: <https://w3id.org/event-retyping-pattern/example/> .

ex:T1 a erp:EventSortal .
ex:T2 a erp:EventSortal .
ex:T3 a erp:EventSortal .
ex:chain_event a erp:Occurrent .
ex:classify_chain_1 a erp:ClassificationAct .
ex:classify_chain_2 a erp:ClassificationAct .
ex:classify_chain_3 a erp:ClassificationAct .
ex:ice_chain_1 a erp:InformationContentEntity .
ex:ice_chain_2 a erp:InformationContentEntity .
ex:ice_chain_3 a erp:InformationContentEntity .
ex:warrant_chain_2 a erp:SupersessionWarrant .
ex:warrant_chain_3 a erp:SupersessionWarrant .
ex:typing_chain_1 a erp:TypingAssertion .
ex:typing_chain_2 a erp:TypingAssertion .
ex:typing_chain_3 a erp:TypingAssertion .
ex:classify_chain_1 erp:produces ex:ice_chain_1 .
ex:classify_chain_2 erp:produces ex:ice_chain_2 .
ex:classify_chain_3 erp:produces ex:ice_chain_3 .
ex:classify_chain_1 erp:precedes ex:classify_chain_2 .
ex:classify_chain_2 erp:precedes ex:classify_chain_3 .
ex:ice_chain_1 erp:about ex:chain_event .
ex:ice_chain_2 erp:about ex:chain_event .
ex:ice_chain_3 erp:about ex:chain_event .
ex:ice_chain_1 erp:assertsTyping ex:typing_chain_1 .
ex:ice_chain_2 erp:assertsTyping ex:typing_chain_2 .
ex:ice_chain_3 erp:assertsTyping ex:typing_chain_3 .
ex:typing_chain_1 erp:typingOccurrence ex:chain_event .
ex:typing_chain_2 erp:typingOccurrence ex:chain_event .
ex:typing_chain_3 erp:typingOccurrence ex:chain_event .
ex:typing_chain_1 erp:typingSortal ex:T1 .
ex:typing_chain_2 erp:typingSortal ex:T2 .
ex:typing_chain_3 erp:typingSortal ex:T3 .
ex:ice_chain_2 erp:supersedes ex:ice_chain_1 .
ex:ice_chain_3 erp:supersedes ex:ice_chain_2 .
ex:ice_chain_2 erp:hasSupersessionWarrant ex:warrant_chain_2 .
ex:ice_chain_3 erp:hasSupersessionWarrant ex:warrant_chain_3 .
ex:warrant_chain_2 erp:warrantedReplacementOf ex:ice_chain_1 .
ex:warrant_chain_2 erp:maintenancePurpose "intermediate chain maintenance" .
ex:warrant_chain_3 erp:warrantedReplacementOf ex:ice_chain_2 .
ex:warrant_chain_3 erp:maintenancePurpose "latest chain maintenance" .
